{
  "lr": 0.001,
  "optimizer": "sgd",
  "max_epochs": 50,
  "dropout": 0.0,
  "early_stopping": true,
  "early_stopping_patience": 6,
  "early_stopping_delta": 0.05,
  "lr_scheduler": "warmup_cosine_annealing",
  "log_losses": "both",
  "lr_scheduler_kwargs": {
    "base_lr": 1e-5,
    "warmup_epochs": 2,
    "num_epochs": 4
  },
  "optimizer_kwargs": {
    "momentum": 0.9
  }
}